# ============================================================================
# Địa chỉ Backend (Spring Boot) — máy đối phương trong cùng mạng Wi-Fi/LAN.
# ----------------------------------------------------------------------------
# Sau này nếu bạn của bạn đổi IP (đổi Wi-Fi, khởi động lại router...), CHỈ CẦN
# sửa đúng 1 dòng dưới đây rồi tắt/bật lại lệnh `npm run dev`.
#
# Biến phải bắt đầu bằng NEXT_PUBLIC_ thì trình duyệt mới đọc được (quy ước của Next.js).
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8080
